# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-opus-4-6

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pixelcoder
DB_USER=postgres
DB_PASSWORD=pixelcoder

# Cycle Configuration
CYCLE_INTERVAL_HOURS=3
START_DATE=2026-04-01
CYCLE_LOGS_RETAIN_DAYS=90

# Budget — soft daily token limit (~500 SEK/month with Opus 4.6)
# Character gets told how much "energy" is left and adjusts behavior.
# Not a hard kill — just influences mood toward resting when near limit.
DAILY_TOKEN_BUDGET=120000

# Admin
API_SECRET=change-me-to-something-secret

# Server
PORT=3000
NODE_ENV=development
